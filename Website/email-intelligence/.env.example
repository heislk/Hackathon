# Email Intelligence Service - Environment Variables
# Copy this file to .env and fill in your values

# Model directory (where the trained model is saved/loaded from)
MODEL_DIR=./model

# Data directories
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed

# Training config
TRAINING_EPOCHS=3
TRAINING_BATCH_SIZE=16
LEARNING_RATE=2e-5
MAX_TOKEN_LENGTH=512

# API config
API_HOST=0.0.0.0
API_PORT=8000

# Logging (set to DEBUG to see redacted text fragments in logs)
LOG_LEVEL=INFO

# Whether to enable Presidio for PII detection (set to false to skip — not recommended)
ENABLE_PII_REDACTION=true
